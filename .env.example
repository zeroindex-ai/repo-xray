# Turso libsql. Local dev can use a file DB: TURSO_DATABASE_URL=file:local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Anthropic API key — required. The /api/analyze agent calls Claude.
ANTHROPIC_API_KEY=

# GitHub token — optional but recommended. Lifts the GitHub API rate limit
# from 60/hr (unauthenticated) to 5000/hr. Public-repo read-only is enough.
GITHUB_TOKEN=

# Basic-auth password for /admin/*.
ADMIN_PASSWORD=

# Optional: salt for the rate-limit client-key hash. Set a random value in
# production so client keys aren't guessable. Defaults to empty.
RATE_LIMIT_SALT=

# Optional: observability dual-write to trace-pack. Set both to emit one event
# per analysis to trace-pack's /api/ingest; omit either to disable (no-op).
# TRACE_PACK_TOKEN must match trace-pack's SOURCE_TOKEN_REPO_XRAY.
# TRACE_PACK_URL=https://traces.zeroindex.ai
# TRACE_PACK_TOKEN=
# TRACE_PACK_SOURCE=repo-xray

# Optional cost/abuse tuning (sensible defaults applied in code if unset):
#   ANALYZE_DAILY_CAP        per-client analyses per UTC day (default 5)
#   GLOBAL_DAILY_USD_CEILING global spend ceiling in USD per UTC day (default 5)
#   MAX_REPO_FILES           decline repos larger than this many files (default 2000)
# ANALYZE_DAILY_CAP=5
# GLOBAL_DAILY_USD_CEILING=5
# MAX_REPO_FILES=2000
