# Turso libsql
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Basic-auth password for /admin/*
ADMIN_PASSWORD=

# --- Optional: only if this service has an upstream consumer ---
# Per-source bearer token expected on authenticated ingest endpoints.
# Add one env var per consumer source, named SOURCE_TOKEN_<UPPER_SOURCE>.
# SOURCE_TOKEN_EXAMPLE=

# --- Optional: only if this service runs a Vercel Cron job ---
# Shared secret required by the cron route (set in Vercel Cron config).
# CRON_SECRET=
